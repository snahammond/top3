<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/header_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp">

    <!-- Accent bar -->
    <View
        android:id="@+id/accent_bar"
        android:layout_width="8dp"
        android:layout_height="80dp"
        android:background="@color/headerAccent"
        android:layout_marginStart="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:clipToPadding="false"
        android:translationZ="2dp"/>

    <!-- Small subtitle -->
    <TextView
        android:id="@+id/tvHeaderTop"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/header_subtitle"
        android:textSize="14sp"
        android:textColor="@color/headerSubtitle"
        android:fontFamily="@font/roboto_medium"
        app:layout_constraintStart_toEndOf="@id/accent_bar"
        app:layout_constraintTop_toTopOf="@id/accent_bar"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginStart="16dp"/>

    <!-- Main title -->
    <TextView
        android:id="@+id/tvHeaderMain"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/header_title_main"
        android:textSize="40sp"
        android:textStyle="bold"
        android:textColor="@color/headerTitle"
        android:fontFamily="@font/roboto_bold"
        app:layout_constraintStart_toStartOf="@id/tvHeaderTop"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTop"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="6dp"/>

    <!-- Country pill (optional; visible when you set text at runtime) -->
    <TextView
        android:id="@+id/tvHeaderCountry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:text="US"
        android:textSize="14sp"
        android:textStyle="600"
        android:textColor="@android:color/white"
        android:background="@drawable/rounded_pill"
        app:layout_constraintTop_toTopOf="@id/tvHeaderMain"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/tvHeaderMain"
        android:visibility="visible"
        android:layout_marginEnd="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
